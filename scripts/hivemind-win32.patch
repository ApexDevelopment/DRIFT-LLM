+        def __init__(self, *args, **kwargs):
+            # multiprocessing.Process silently accepts 'daemon' as a keyword;
+            # threading.Thread also accepts it, so we can forward everything.
+            super().__init__(*args, **kwargs)
+            self.daemon = True  # default matches hivemind's typical usage
+
+        # ------------------------------------------------------------------
+        # Process-compatible additions
+        # ------------------------------------------------------------------
+
+        def terminate(self) -> None:  # noqa: D401
